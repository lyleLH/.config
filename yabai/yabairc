#!/usr/bin/env sh

# Load scripting addition (requires SIP disabled)
sudo yabai --load-sa
yabai -m signal --add event=dock_did_restart action="sudo yabai --load-sa"

# BSP layout (auto dwindle like Hyprland)
yabai -m config layout bsp

# Window gaps
yabai -m config top_padding    6
yabai -m config bottom_padding 6
yabai -m config left_padding   6
yabai -m config right_padding  6
yabai -m config window_gap     6

# Mouse
yabai -m config mouse_follows_focus on
yabai -m config focus_follows_mouse autofocus
yabai -m config mouse_modifier alt
yabai -m config mouse_action1 move
yabai -m config mouse_action2 resize
yabai -m config mouse_drop_action swap

# Auto-split ratio
yabai -m config split_ratio 0.5

# New window spawns to the right/bottom (dwindle feel)
yabai -m config window_placement second_child

# New window inserts at focused window (not end of tree)
yabai -m config window_insertion_point focused

# Split direction auto (based on window dimensions: wide=vertical, tall=horizontal)
yabai -m config split_type auto

# Window opacity (subtle: focused opaque, unfocused slightly dimmed)
yabai -m config window_opacity on
yabai -m config active_window_opacity 1.0
yabai -m config normal_window_opacity 0.99
yabai -m config window_opacity_duration 0.15

# Window animation (0 = instant, no animation)
yabai -m config window_animation_duration 0.0

# Fullscreen zoom persists when layout changes
yabai -m config window_zoom_persist on

# Window shadow only for floating
yabai -m config window_shadow float

# Window origin follows focused display
yabai -m config window_origin_display focused

# Menu bar opacity (0.0 = hidden, 1.0 = normal)
yabai -m config menubar_opacity 1.0

# ---- Signals ----
# Auto-focus next window when a window is closed
yabai -m signal --add event=window_destroyed action="yabai -m query --windows --window &> /dev/null || yabai -m window --focus recent"
yabai -m signal --add event=application_terminated action="yabai -m query --windows --window &> /dev/null || yabai -m window --focus recent"
# Auto-focus next window when app is hidden
yabai -m signal --add event=window_minimized action="yabai -m query --windows --window &> /dev/null || yabai -m window --focus recent"
yabai -m signal --add event=application_hidden action="yabai -m query --windows --window &> /dev/null || yabai -m window --focus recent"
# Auto-focus first window when switching spaces
yabai -m signal --add event=space_changed action="yabai -m window --focus first 2>/dev/null"
# Auto-float windows that can't be resized (dialogs, preferences, wizards)
yabai -m signal --add event=window_created action='yabai -m query --windows --window $YABAI_WINDOW_ID | /opt/homebrew/bin/jq -er "if .\"can-resize\" == false and .\"is-floating\" == false then halt_error else empty end" 2>/dev/null && yabai -m window $YABAI_WINDOW_ID --toggle float 2>/dev/null'


# ---- Float rules ----
# System utilities (fixed size, not workspace apps)
yabai -m rule --add app="^System Settings$" manage=off
yabai -m rule --add app="^Activity Monitor$" manage=off
yabai -m rule --add app="^App Store$" manage=off
yabai -m rule --add app="^Archive Utility$" manage=off
yabai -m rule --add app="^Calculator$" manage=off
yabai -m rule --add app="^Calendar$" manage=off
yabai -m rule --add app="^Preview$" manage=off
yabai -m rule --add app="^Books$" manage=off
yabai -m rule --add app="^Dictionary$" manage=off
# Launchers & overlays
yabai -m rule --add app="^Alfred$" manage=off
yabai -m rule --add app="^Raycast$" manage=off
yabai -m rule --add app="^Shottr$" manage=off
yabai -m rule --add app="^KeyCastr$" manage=off
yabai -m rule --add app="^Typeless$" manage=off
yabai -m rule --add app="^TopNotch$" manage=off
# Settings apps
yabai -m rule --add app="^Karabiner-Elements$" manage=off
yabai -m rule --add app="^Karabiner-EventViewer$" manage=off
yabai -m rule --add app="^Bitwarden$" manage=off
# Finder & Marta: fully floating, centered at ~67% screen size
yabai -m rule --add app="^Finder$" manage=off grid=6:6:1:1:4:4
yabai -m rule --add app="^Marta$" manage=off grid=6:6:1:1:4:4
# Zoom (video call UI fights tiling)
yabai -m rule --add app="^zoom.us$" manage=off
# Xcode: tile main windows, float dialogs (no sleep hack)
yabai -m rule --add app="^Xcode$" subrole="^AXStandardWindow$" manage=on
yabai -m rule --add app="^Xcode$" subrole="^AXDialog$" manage=off

# ---- Ensure 9 spaces exist (via Mission Control automation) ----
~/.config/scripts/ensure-spaces.sh 9

# ---- Space labels ----
yabai -m space 1 --label web
yabai -m space 2 --label code
yabai -m space 3 --label term
yabai -m space 4 --label chat
yabai -m space 5 --label notes
yabai -m space 6 --label ai
yabai -m space 7 --label misc
yabai -m space 8 --label extra
yabai -m space 9 --label scratchpad

# ---- Space assignments ----
yabai -m rule --add app="^Google Chrome$" space=1
yabai -m rule --add app="^Firefox$" space=1
yabai -m rule --add app="^Sublime Text$" space=2
# Terminals: no fixed space, open on current workspace
# yabai -m rule --add app="^Ghostty$" space=3
# yabai -m rule --add app="^iTerm2$" space=3
# yabai -m rule --add app="^kitty$" space=3
# yabai -m rule --add app="^cmux$" space=3
yabai -m rule --add app="^Telegram$" space=4
yabai -m rule --add app="^Signal$" space=4
yabai -m rule --add app="^Slack$" space=4
yabai -m rule --add app="^WeChat$" space=4
yabai -m rule --add app="^Typora$" space=5
# Notes & Reminders: native scratchpad (auto floating, toggle with --toggle)
yabai -m rule --add app="^Notes$" scratchpad=notes grid=6:6:1:1:4:4
yabai -m rule --add app="^Reminders$" manage=off grid=6:6:1:1:4:4
yabai -m rule --add app="^Obsidian$" space=5
yabai -m rule --add app="^Xcode$" space=5
# Simulator: floating + sticky + on top (visible across all spaces)
yabai -m rule --add app="^Simulator$" manage=off sticky=on sub-layer=above
yabai -m rule --add app="^LM Studio$" space=6
yabai -m rule --add app="^ChatGPT$" space=6

# ---- Auto-follow: focus the space when a window is moved there by rules ----
yabai -m signal --add event=window_created action="/opt/homebrew/bin/yabai -m space --focus \$(/opt/homebrew/bin/yabai -m query --windows --window \$YABAI_WINDOW_ID | /usr/bin/python3 -c 'import sys,json;print(json.load(sys.stdin)[\"space\"])')"

echo "yabai configuration loaded"
