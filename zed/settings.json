{
  // ── Appearance ─────────────────────────────────────
  "agent_ui_font_size": 16.0,
  "agent": {
    "dock": "left",
    "default_width": 640,
    "favorite_models": [],
    "profiles": {
      "container-use": {
        "name": "container-use",
        "tools": {},
        "enable_all_context_servers": false,
        "context_servers": {}
      },
      "tofulab-zed": {
        "name": "Tofulab-zed",
        "tools": {},
        "enable_all_context_servers": false,
        "context_servers": {}
      }
    },
    "model_parameters": []
  },
  "context_servers": {
    "container-use-mcp": {
      "enabled": true,
      "remote": false,
      "settings": {
        "cu_path": "/opt/homebrew/bin/container-use"
      }
    }
  },
  "theme": {
    "mode": "system",
    "light": "Ayu Light",
    "dark": "Catppuccin Frappé (Blue Blur+)"
  },
  "icon_theme": "Catppuccin Mocha",
  "buffer_font_family": "Maple Mono",
  "buffer_font_size": 15,
  "ui_font_family": "Maple Mono",
  "ui_font_size": 15,

  // ── Editor ─────────────────────────────────────────
  "tab_size": 2,
  "preferred_line_length": 80,
  "soft_wrap": "none",
  "show_whitespaces": "boundary",
  "relative_line_numbers": "enabled",
  "cursor_blink": true,
  "scroll_beyond_last_line": "off",
  "vertical_scroll_margin": 15,
  "gutter": {
    "code_actions": true,
    "folds": true,
    "runnables": true
  },
  "indent_guides": {
    "enabled": true,
    "coloring": "indent_aware"
  },
  "minimap": {
    "show": "never"
  },
  "scrollbar": {
    "show": "never"
  },
  "inlay_hints": {
    "enabled": true
  },

  // ── Vim ────────────────────────────────────────────
  "vim_mode": true,
  "base_keymap": "VSCode",
  "command_aliases": {
    "W": "w",
    "Wq": "wq",
    "Q": "q"
  },

  // ── Save & Format ─────────────────────────────────
  "autosave": {
    "after_delay": {
      "milliseconds": 1000
    }
  },
  "format_on_save": "on",
  "formatter": "language_server",

  // ── Title bar ──────────────────────────────────────
  "title_bar": {
    "show_branch_icon": true
  },

  // ── Session ────────────────────────────────────────
  "session": {
    "trust_all_worktrees": true,
    "restore_unsaved_buffers": true
  },

  // ── Terminal ───────────────────────────────────────
  "terminal": {
    "font_family": "JetBrainsMono Nerd Font",
    "font_size": 15,
    "blinking": "on",
    "shell": {
      "program": "zsh"
    }
  },

  // ── File tree ──────────────────────────────────────
  "project_panel": {
    "dock": "right",
    "auto_reveal_entries": true,
    "indent_size": 16,
    "auto_fold_dirs": true
  },

  // ── Git ────────────────────────────────────────────
  "git": {
    "inline_blame": {
      "enabled": true,
      "delay_ms": 500
    }
  },

  // ── Languages ──────────────────────────────────────
  "languages": {
    "JavaScript": {
      "tab_size": 2,
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--stdin-filepath", "{buffer_path}"]
        }
      }
    },
    "TypeScript": {
      "tab_size": 2,
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--stdin-filepath", "{buffer_path}"]
        }
      }
    },
    "TSX": {
      "tab_size": 2,
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--stdin-filepath", "{buffer_path}"]
        }
      }
    },
    "JSON": {
      "tab_size": 2,
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--stdin-filepath", "{buffer_path}"]
        }
      }
    },
    "CSS": {
      "tab_size": 2,
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--stdin-filepath", "{buffer_path}"]
        }
      }
    },
    "HTML": {
      "tab_size": 2,
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--stdin-filepath", "{buffer_path}"]
        }
      }
    },
    "Markdown": {
      "soft_wrap": "preferred_line_length",
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--stdin-filepath", "{buffer_path}"]
        }
      }
    },
    "Python": {
      "tab_size": 4,
      "formatter": {
        "external": {
          "command": "black",
          "arguments": ["--stdin-filename", "{buffer_path}", "-"]
        }
      }
    },
    "Lua": {
      "tab_size": 2,
      "formatter": {
        "external": {
          "command": "stylua",
          "arguments": ["-"]
        }
      }
    }
  }
}
