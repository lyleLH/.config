# === Font ===
font-family = "Maple Mono"
font-style = "Regular"
font-style-bold = "Medium"
font-style-italic = "Italic"
font-style-bold-italic = "Medium Italic"
font-size = 16
font-thicken = true
font-codepoint-map = U+4E00-U+9FFF=LXGW WenKai Mono
font-codepoint-map = U+3400-U+4DBF=LXGW WenKai Mono
font-codepoint-map = U+3000-U+303F=LXGW WenKai Mono
font-codepoint-map = U+FF00-U+FFEF=LXGW WenKai Mono
grapheme-width-method = unicode
adjust-cell-width = 0%

# === Theme (auto follow system dark/light) ===
theme = light:Dayfox,dark:Catppuccin Macchiato

# === Cursor ===
cursor-style = bar
cursor-style-blink = true
cursor-click-to-move = true

# === Window ===
window-padding-x = 10
window-padding-y = 8
window-save-state = always
window-decoration = auto
window-theme = ghostty
macos-titlebar-style = hidden
macos-window-shadow = true
macos-option-as-alt = true

# === Background ===
background-opacity = 0.98
background-blur-radius = 25

# === Shaders ===

# === Scrollback ===
scrollback-limit = 50000

# === Mouse ===
mouse-hide-while-typing = true
link-url = true
copy-on-select = clipboard

# === Shell integration ===
shell-integration = zsh
shell-integration-features = cursor,sudo,title

# === Quick terminal (drop-down) ===
keybind = global:f13=toggle_quick_terminal
quick-terminal-position = top
quick-terminal-screen = main
quick-terminal-animation-duration = 0.15

# === Splits ===
keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down
keybind = cmd+opt+left=goto_split:left
keybind = cmd+opt+right=goto_split:right
keybind = cmd+opt+up=goto_split:top
keybind = cmd+opt+down=goto_split:bottom
keybind = cmd+opt+equal=equalize_splits

# === Tabs ===
keybind = cmd+t=new_tab
keybind = cmd+shift+left=previous_tab
keybind = cmd+shift+right=next_tab

# === Font size ===
keybind = cmd+equal=increase_font_size:1
keybind = cmd+minus=decrease_font_size:1
keybind = cmd+0=reset_font_size

# === Misc ===
keybind = cmd+shift+comma=open_config
keybind = cmd+k=clear_screen
confirm-close-surface = false
auto-update = check
custom-shader = /Users/hao92/ghostty-shaders/starfield.glsl
custom-shader = /Users/hao92/ghostty-cursor-shaders/cursor_tail.glsl
custom-shader-animation = always
