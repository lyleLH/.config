# === Font ===
font-family = "Maple Mono NF"
font-family = "LXGW WenKai"
font-style-bold = "Medium"
font-style-bold-italic = "Medium Italic"
font-size = 14
font-thicken = true
grapheme-width-method = unicode
adjust-cell-width = 0%

# === Theme ===
theme = Dayfox

# === Cursor ===
cursor-style = bar
cursor-style-blink = true
cursor-click-to-move = true

# === Window ===
window-padding-x = 10
window-padding-y = 8
window-save-state = always
window-decoration = auto
window-theme = ghostty

# === Background ===
background-opacity = 0.92
background-blur-radius = 25

# === Scrollback ===
scrollback-limit = 50000

# === Mouse ===
mouse-hide-while-typing = true
link-url = true
copy-on-select = clipboard

# === Shell integration ===
shell-integration = zsh
shell-integration-features = cursor,sudo,title

# === Splits ===
keybind = ctrl+d=new_split:right
keybind = ctrl+shift+d=new_split:down
keybind = ctrl+alt+left=goto_split:left
keybind = ctrl+alt+right=goto_split:right
keybind = ctrl+alt+up=goto_split:top
keybind = ctrl+alt+down=goto_split:bottom
keybind = ctrl+alt+equal=equalize_splits

# === Tabs ===
keybind = ctrl+t=new_tab
keybind = ctrl+shift+left=previous_tab
keybind = ctrl+shift+right=next_tab

# === Font size ===
keybind = ctrl+equal=increase_font_size:1
keybind = ctrl+minus=decrease_font_size:1
keybind = ctrl+0=reset_font_size

# === Shell ===
command = /usr/bin/zsh

# === Misc ===
keybind = ctrl+shift+comma=open_config
keybind = ctrl+k=clear_screen
confirm-close-surface = false
