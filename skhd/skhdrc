# ---- Hyprland-style keybindings for yabai ----

# App launcher managed by Karabiner (o-mode / w-mode)

# Focus window
alt - h : yabai -m window --focus west
alt - j : yabai -m window --focus south
alt - k : yabai -m window --focus north
alt - l : yabai -m window --focus east

# Swap window
shift + alt - h : yabai -m window --swap west
shift + alt - j : yabai -m window --swap south
shift + alt - k : yabai -m window --swap north
shift + alt - l : yabai -m window --swap east

# Move window to space managed by Karabiner (alt+shift+number)

# Fullscreen toggle
alt - f : yabai -m window --toggle zoom-fullscreen

# Native macOS fullscreen
shift + alt - f : yabai -m window --toggle native-fullscreen

# Float / unfloat
shift + alt - space : yabai -m window --toggle float --grid 4:4:1:1:2:2

# Cycle windows
alt - n : yabai -m window --focus next || yabai -m window --focus first
shift + alt - n : yabai -m window --focus prev || yabai -m window --focus last

# Cycle monitors
alt - 0x2B : yabai -m display --focus prev || yabai -m display --focus last  # alt-,
alt - 0x2F : yabai -m display --focus next || yabai -m display --focus first # alt-.

# Move window to monitor (focus follows)
shift + alt - 0x2B : yabai -m window --display prev && yabai -m display --focus prev
shift + alt - 0x2F : yabai -m window --display next && yabai -m display --focus next

# Resize
alt - 0x18 : yabai -m window --resize right:50:0 || yabai -m window --resize left:50:0   # alt-=
alt - 0x1B : yabai -m window --resize right:-50:0 || yabai -m window --resize left:-50:0  # alt--

# Layout toggle
alt - 0x2C : yabai -m space --layout bsp    # alt-/
shift + alt - 0x2C : yabai -m space --layout stack

# Close window
alt - q : yabai -m window --close
